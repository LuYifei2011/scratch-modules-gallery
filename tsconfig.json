{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "lib": ["ESNext", "DOM"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": false,
    "target": "ESNext",
    "types": ["bun-types"]
  },
  "include": ["site.config.ts", "scripts/**/*.ts", "src/client/**/*.ts"],
  "exclude": ["tests/**"]
}
