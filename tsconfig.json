{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "lib": ["ESNext", "DOM"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": false,
    "target": "ESNext",
    "types": ["bun"]
  },
  "include": ["site.config.ts", "scripts/**/*.ts", "src/client/**/*.ts", "tests/**/*.ts"]
}
