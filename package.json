{
  "name": "scratch-modules-gallery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build.js",
    "build:fast": "node ./scripts/build.js --fast",
    "dev": "node ./scripts/dev-server.js",
    "dev:https": "powershell -NoProfile -Command \"$env:HTTPS='1'; node ./scripts/dev-server.js\"",
    "format": "prettier --write .",
    "format:scripts": "node ./scripts/format-scratchblocks.js --all",
    "test": "node --test tests/*.test.js",
    "check-i18n": "node scripts/check-translations.js"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@xmldom/xmldom": "^0.9.10",
    "fast-glob": "^3.3.3",
    "favicons": "^7.3.0",
    "formidable": "^3.5.4",
    "fs-extra": "^11.3.5",
    "html-minifier-next": "^7.0.0",
    "marked": "^18.0.5",
    "minisearch": "^7.2.0",
    "nunjucks": "^3.2.4",
    "scratchblocks-plus": "^1.1.2",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@lezer/highlight": "^1.2.3",
    "chokidar": "^3.6.0",
    "prettier": "^3.9.1",
    "selfsigned": "^5.5.0"
  }
}
