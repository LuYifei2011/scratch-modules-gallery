{% import "partials/icons.njk" as icons %}
{% import "partials/module-macros.njk" as m %}
{% extends "layouts/base.njk" %}
{% block title %}{{ module.name }} - {{ config.siteName }}{% endblock %}
{% block og_title %}{{ module.name }} - {{ config.siteName }}{% endblock %}
{% block og_description %}{{ module.description }}{% endblock %}
{% block og_image %}{{ config.baseUrl }}/{{ locale }}/modules/{{ module.slug }}/cover.png{% endblock %}
{% block twitter_title %}{{ module.name }} - {{ config.siteName }}{% endblock %}
{% block twitter_description %}{{ module.description }}{% endblock %}
{% block twitter_image %}{{ config.baseUrl }}/{{ locale }}/modules/{{ module.slug }}/cover.png{% endblock %}
{% set canonical = '/' + locale + '/modules/' + module.slug + '/' %}
{% block meta_description %}{{ module.description }}{% endblock %}
{% block meta_keywords %}<meta name="keywords" content="{{ module.keywordsFinalStr }}" />{% endblock %}
{% block head_extra %}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org", 
        "@type": "SoftwareSourceCode", 
        "name": "{{ module.name | replace('"','\"') }}",
        "description": "{{ module.description | replace('"','\"') }} ", 
        "programmingLanguage": "Scratch", 
        "keywords": "{{ module.keywordsFinalStr }}", 
        "url": "{{ config.baseUrl }}/{{ locale }}/modules/{{ module.slug }}/"
    }
    </script>
{% endblock %}
{% block content %}
    <article class="module-detail">
        <div style="display: flex;
                    justify-content: space-between;
                    align-items: baseline;
                    flex-wrap: wrap;
                    gap: var(--space-md)">
            <h1>{{ module.name }}</h1>
            {% if IS_DEV %}
                <a href="/__dev/editor/?module={{ module.id }}"
                   class="btn btn-sm btn-primary"
                   style="height: 20px;
                          display:inline-flex;
                          align-items:center;
                          gap:6px">
                    {{ icons.iconEdit(14, 14) }}
                    {{ t.module.editModule }}
                </a>
            {% endif %}
        </div>
        <p>{{ module.description }}</p>
        <p class="tags">
            {% for t in module.tags %}<span class="tag">{{ t }}</span>{% endfor %}
        </p>
        {% if IS_DEV and module.keywordsStr %}
            <p style="display: flex;
                      align-items: center;
                      gap: 8px;
                      margin: var(--space-md) 0 0 0;
                      font-size: 0.9em">
                {{ icons.iconDebug(16, 16) }} Keywords:
                <span>{{ module.keywordsStr }}</span>
            </p>
        {% endif %}
        {% if module.contributors.length %}
            <p class="contributors">
                {{ t.module.contributors }}:
                {% for c in module.contributors %}
                    <span class="contributor">
                        {% if c.url %}
                            <a href="{{ c.url }}" target="_blank" rel="noopener">{{ c.name }}</a>
                        {% else %}
                            {{ c.name }}
                        {% endif %}
                    </span>
                {% endfor %}
            </p>
        {% endif %}
        <section>
            <h2>{{ t.module.scripts }}</h2>
            <div class="sb-style-switcher" style="margin-bottom: var(--space-lg);">
                <label for="sb-style">{{ t.module.renderStyle }}</label>
                <select id="sb-style" class="select-inline">
                    <option value="scratch3" selected>Scratch 3</option>
                    <option value="scratch3-high-contrast">Scratch 3 ({{ t.module.highContrast }})</option>
                    <option value="scratch2">Scratch 2</option>
                </select>
            </div>
            <div class="sb-translate-switcher" style="margin-bottom: var(--space-lg);">
                <label for="sb-translate">{{ t.module.translateTo }}</label>
                <select id="sb-translate" class="select-inline">
                    <option value="no-translate" selected>{{ t.module.noTranslate }}</option>
                    {% for lang in scratchblocksLanguages %}<option value="{{ lang.code }}">{{ lang.name }}</option>{% endfor %}
                </select>
            </div>
            {% if module.scripts and module.scripts.length %}
                {% for s in module.scripts %}
                    {% if s.imported %}
                        {{ m.renderImportedDetails(s, t, IS_DEV, icons, pageBase) }}
                    {% else %}
                        <div class="script-block">
                            {% if s.title %}<h3 class="script-title">{{ s.title }}</h3>{% endif %}
                            {% if s.leadingImports %}
                                {% for imp in s.leadingImports %}
                                    {{ m.renderImportedDetails(imp, t, IS_DEV, icons, pageBase) }}
                                {% endfor %}
                            {% endif %}
                            {{ m.renderSbBlock(s.content, module.id, s.id, s.id, t, IS_DEV, icons) }}
                        </div>
                    {% endif %}
                {% endfor %}
            {% endif %}
        </section>
        {% if module.variables.length %}
            <section>
                <h2>{{ t.module.variablesTitle }}</h2>
                <table class="variables">
                    <thead>
                        <tr>
                            <th>{{ t.module.varName }}</th>
                            <th>{{ t.module.varType }}</th>
                            <th>{{ t.module.varScope }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for v in module.variables %}
                            {% set typeMap = t.module.typeMap %}
                            {% set scopeMap = t.module.scopeMap %}
                            <tr data-display-name="{{ v.displayName or v.name }}"
                                data-type="{{ v.type }}"
                                data-scope="{{ v.scope }}">
                                <td class="var-name-cell">
                                    <div class="var-name-wrap">
                                        <span class="var-name-block">{{ v.displayName or v.name }}</span>
                                        <button class="sb-action sb-copy var-copy"
                                                type="button"
                                                aria-label="{{ t.module.copyScript }}"
                                                title="{{ t.module.copyScript }}">
                                            {{ icons.iconCopy() }}
                                            {{ icons.iconCheck() }}
                                        </button>
                                    </div>
                                </td>
                                <td>{{ typeMap[v.type] or v.type }}</td>
                                <td>{{ scopeMap[v.scope] or v.scope }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>
        {% endif %}
        {% if module.notesHtml %}
            <section>
                <h2>{{ t.module.notes }}</h2>
                {{ module.notesHtml | safe }}
            </section>
        {% endif %}
        {% if module.hasDemo %}
            <section>
                <div class="demo-header">
                    <h2 style="margin:0;">{{ t.module.demo }}</h2>
                    <div class="demo-actions">
                        <a class="btn btn-primary demo-btn"
                           href="https://turbowarp.org/editor?project_url={{ (config.baseUrl + '/modules/' + module.slug + '/demo.sb3') | urlencode }}"
                           target="_blank"
                           rel="noopener">
                            <span class="btn-icon">{{ icons.iconEdit(18, 18) }}</span>
                            <span class="btn-text">{{ t.module.openInTW }}</span>
                        </a>
                        <a class="btn demo-btn"
                           href="{{ config.baseUrl }}/modules/{{ module.slug }}/demo.sb3"
                           download="{{ module.slug }}-demo.sb3">
                            <span class="btn-icon">{{ icons.iconDownload(18, 18) }}</span>
                            <span class="btn-text">{{ t.module.downloadDemo }}</span>
                        </a>
                    </div>
                </div>
                <iframe src="https://turbowarp.org/embed?project_url={{ (config.baseUrl + '/modules/' + module.slug + '/demo.sb3') | urlencode }}&settings-button&addons=pause,clones"
                        class="demo-iframe"
                        allowtransparency="true"
                        frameborder="0"
                        scrolling="no"
                        allowfullscreen
                        loading="lazy"></iframe>
            </section>
        {% endif %}
        {% if module.references.length %}
            <section>
                <h2>{{ t.module.references }}</h2>
                <ul>
                    {% for r in module.references %}
                        <li>
                            <a href="{{ r.url }}" target="_blank" rel="noopener">{{ r.title }}</a>
                            {% if r.type %}<em>({{ r.type }})</em>{% endif %}
                        </li>
                    {% endfor %}
                </ul>
            </section>
        {% endif %}
    </article>
{% endblock %}
{% block page_scripts %}
    <link rel="stylesheet" href="{{ assetBase }}/module.css" />
    <script type="module" src="{{ assetBase }}/module.js"></script>
{% endblock %}
