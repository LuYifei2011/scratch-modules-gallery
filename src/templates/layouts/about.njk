{% extends "layouts/base.njk" %}

{% block title %}{{ t.about.title }} - {{ config.siteName }}{% endblock %}
{% block meta_description %}{{ t.about.description }}{% endblock %}

{% block head_extra %}
<link rel="stylesheet" href="{{ assetBase }}/components.css" />
{% endblock %}

{% block content %}
<main class="container">
    <article class="about-content">
        <h1>{{ t.about.title }}</h1>
        
        <section class="about-section">
            <h2>{{ t.about.whatIsThis }}</h2>
            <p>{{ t.about.whatIsThisContent }}</p>
        </section>

        <section class="about-section">
            <h2>{{ t.about.howToUse }}</h2>
            <p>{{ t.about.howToUseContent }}</p>
            <ol>
                <li>{{ t.about.step1 }}</li>
                <li>{{ t.about.step2 }}</li>
                <li>{{ t.about.step3 }}</li>
            </ol>
        </section>

        <section class="about-section">
            <h2>{{ t.about.contribute }}</h2>
            <p>{{ t.about.contributeContent }}</p>
            {% if config.repoUrl %}
            <p>
                <a href="{{ config.repoUrl }}" target="_blank" rel="noopener" class="btn-link">
                    {{ t.about.viewOnGitHub }}
                </a>
            </p>
            {% endif %}
        </section>

        <section class="about-section">
            <h2>{{ t.about.license }}</h2>
            <p>{{ t.about.licenseContent.sourceCode }}</p>
            <p>{{ t.about.licenseContent.modules }}</p>
        </section>

        <section class="about-section" id="support">
            <h2>{{ t.about.support }}</h2>
            <p>{{ t.about.supportContent }}</p>
            <script type='text/javascript' src='https://storage.ko-fi.com/cdn/widget/Widget_2.js'></script>
            <script type='text/javascript'>
                kofiwidget2.init('{{ t.base.supportKoFi }}', '#72a4f2', 'H2H21ME5VO');
                kofiwidget2.draw();
            </script>
            <div class="donate-images">
                <div class="donate-item">
                    <img src="{{ assetBase }}/assets/donate/alipay.jpg" />
                    <hr class="donate-divider" />
                    <span class="donate-label">{{ t.about.donateAlipay }}</span>
                </div>
                <div class="donate-item">
                    <img src="{{ assetBase }}/assets/donate/wechatpay.png" />
                    <hr class="donate-divider" />
                    <span class="donate-label">{{ t.about.donateWeChatPay }}</span>
                </div>
                <div class="donate-item">
                    <img src="{{ assetBase }}/assets/donate/qqwallet.png" />
                    <hr class="donate-divider" />
                    <span class="donate-label">{{ t.about.donateQQWallet }}</span>
                </div>
            </div>
        </section>

        <section class="about-section">
            <h2>{{ t.about.thirdPartyLicenses }}</h2>
            <p>{{ t.about.thirdPartyLicensesContent }}</p>
            <ul>
                <li><a href="{{ assetBase }}/thirdparty/lucide.txt" target="_blank" rel="noopener">Lucide Icons</a></li>
            </ul>
        </section>

        <div class="back-link">
            <a href="{{ pageBase }}/">← {{ t.about.backToHome }}</a>
        </div>
    </article>
</main>

<style>
.about-content {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md);
}

.about-section {
    margin-bottom: var(--space-xl);
}

.about-section h2 {
    color: var(--color-brand);
    margin-bottom: var(--space-md);
    font-size: var(--font-size-lg);
}

.about-section p {
    line-height: 1.6;
    margin-bottom: var(--space-md);
}

.about-section ol {
    line-height: 1.8;
    padding-left: var(--space-lg);
}

.about-section ol li {
    margin-bottom: var(--space-sm);
}

.donate-images {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-md);
}

.donate-item {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.donate-item img {
    width: 100%;
    height: auto;
    object-fit: contain;
}

.donate-divider {
    width: 40%;
    border: none;
    border-top: 2px solid var(--color-border-light);
    margin: var(--space-sm) 0;
}

.donate-label {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    text-align: center;
}

@media (max-width: 600px) {
    .donate-images {
        flex-direction: column;
    }

    .donate-item {
        flex: none;
        width: 100%;
    }
}

.btn-link {
    display: inline-block;
    padding: var(--space-sm) var(--space-lg);
    background: var(--color-brand);
    color: white;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background var(--transition-base);
}

.btn-link:hover {
    background: var(--color-brand-hover);
}

.back-link {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border-light);
}

.back-link a {
    color: var(--color-brand);
    text-decoration: none;
}

.back-link a:hover {
    text-decoration: underline;
}
</style>
{% endblock %}
