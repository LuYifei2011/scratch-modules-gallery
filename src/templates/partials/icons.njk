{# SVG 图标库 #}
{# 使用方法: {% include "partials/icons.njk" %} 后调用对应的宏 #}

{# 这些图标来自 Lucide Icons (https://lucide.dev/), 使用 ISC 与 MIT 许可 #}
{# 编辑图标 - pencil #}
{% macro iconEdit(width=16, height=16, className="") %}
    <svg class="icon {{ className }}"
         viewBox="0 0 24 24"
         width="{{ width }}"
         height="{{ height }}"
         aria-hidden="true"
         focusable="false">
        <path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z" />
        <path d="m15 5 4 4" />
    </svg>
{% endmacro %}
{# 复制图标 - copy #}
{% macro iconCopy(width=16, height=16, className="") %}
    <svg class="icon icon-copy {{ className }}"
         viewBox="0 0 24 24"
         width="{{ width }}"
         height="{{ height }}"
         aria-hidden="true"
         focusable="false">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
    </svg>
{% endmacro %}
{# 完成图标 - check #}
{% macro iconCheck(width=16, height=16, className="") %}
    <svg class="icon icon-check {{ className }}"
         viewBox="0 0 24 24"
         width="{{ width }}"
         height="{{ height }}"
         aria-hidden="true"
         focusable="false">
        <path d="M20 6 9 17l-5-5" />
    </svg>
{% endmacro %}
{# 语言图标 - languages #}
{% macro iconLanguage(width=16, height=16, className="") %}
    <svg class="icon {{ className }}"
         viewBox="0 0 24 24"
         width="{{ width }}"
         height="{{ height }}"
         aria-hidden="true"
         focusable="false">
        <path d="m5 8 6 6" />
        <path d="m4 14 6-6 2-3" />
        <path d="M2 5h12" />
        <path d="M7 2h1" />
        <path d="m22 22-5-10-5 10" />
        <path d="M14 18h6" />
    </svg>
{% endmacro %}
{# 问号图标 - circle-question-mark #}
{% macro iconCircleQuestionMark(width=16, height=16, className="") %}
    <svg class="icon {{ className }}"
         viewBox="0 0 24 24"
         width="{{ width }}"
         height="{{ height }}"
         aria-hidden="true"
         focusable="false">
        <circle cx="12" cy="12" r="10" />
        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
        <path d="M12 17h.01" />
    </svg>
{% endmacro %}
{# X/关闭图标 - x #}
{% macro iconX(width=16, height=16, className="") %}
    <svg class="icon {{ className }}"
         viewBox="0 0 24 24"
         width="{{ width }}"
         height="{{ height }}"
         aria-hidden="true"
         focusable="false">
        <path d="M18 6 6 18"/>
        <path d="m6 6 12 12"/>
    </svg>
{% endmacro %}
{# 下拉箭头图标 - chevron-down #}
{% macro iconChevronDown(width=16, height=16, className="") %}
    <svg class="icon {{ className }}"
         viewBox="0 0 24 24"
         width="{{ width }}"
         height="{{ height }}"
         aria-hidden="true"
         focusable="false">
        <path d="m6 9 6 6 6-6" />
    </svg>
{% endmacro %}
{# 分享图标 - share-2 #}
{% macro iconShare(width=16, height=16, className="") %}
    <svg class="icon {{ className }}"
         viewBox="0 0 24 24"
         width="{{ width }}"
         height="{{ height }}"
         aria-hidden="true"
         focusable="false">
        <circle cx="18" cy="5" r="3"/>
        <circle cx="6" cy="12" r="3"/>
        <circle cx="18" cy="19" r="3"/>
        <line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/>
        <line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/>
    </svg>
{% endmacro %}

