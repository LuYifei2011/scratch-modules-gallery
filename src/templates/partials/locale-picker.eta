lowerLoc.indexOf('zh-') === 0; }); if (chinese) { return chinese; } } } for (var k = 0; k < ls.length; k++) { var
primary = ls[k].split('-')[0]; var hit = findLocale(function (_loc, lowerLoc) { return lowerLoc.split('-')[0] ===
primary; }); if (hit) { return hit; } } return defaultLocale || null; }
