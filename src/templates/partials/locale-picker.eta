function pickLocale(browserLangs, locales, defaultLocale) { if (!Array.isArray(browserLangs)) { browserLangs =
[navigator.language || '']; } if (!Array.isArray(locales)) { locales = []; } var ls = browserLangs.map(function (l) {
return String(l || '').toLowerCase(); }); function findLocale(match) { for (var i = 0; i < locales.length; i++) { var
loc = String(locales[i] || ''); if (match(loc, loc.toLowerCase())) { return loc; } } return null; } for (var i = 0; i <
ls.length; i++) { var exact = findLocale(function (_loc, lowerLoc) { return lowerLoc === ls[i]; }); if (exact) { return
exact; } } for (var j = 0; j < ls.length; j++) { var l = ls[j]; if (l.indexOf('zh') === 0) { if
